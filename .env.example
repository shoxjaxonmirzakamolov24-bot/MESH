# ==========================================================
# SkillMesh — Muhit o'zgaruvchilari (.env)
# Bu faylni nusxalab `.env` deb nomlang va qiymatlarni to'ldiring.
# Server `dotenv` orqali `.env` faylini o'qiydi (`.env.local` EMAS!).
# ==========================================================

# --- AUTH (MAJBURIY) ---------------------------------------
# Telegram bot token (@BotFather'dan olinadi). initData imzosini tekshirish uchun.
TELEGRAM_BOT_TOKEN=""

# JWT imzo kaliti. Kamida 16 belgi, tasodifiy va maxfiy bo'lsin.
# Masalan: openssl rand -hex 32
JWT_SECRET=""

# Admin huquqiga ega Telegram ID'lar (vergul bilan ajratilgan).
# Masalan: ADMIN_TELEGRAM_IDS="73327,12345678"
ADMIN_TELEGRAM_IDS=""

# Faqat LOKAL ishlab chiqish uchun: Telegram imzosisiz kirishga ruxsat beradi.
# PRODUCTIONDA HECH QACHON "true" QILMANG! (default: o'chirilgan)
ALLOW_DEV_AUTH="false"

# --- AI (ixtiyoriy, bo'lmasa mock javoblar ishlatiladi) -----
# Gemini API kaliti (https://aistudio.google.com/app/apikey).
GEMINI_API_KEY=""

# --- MA'LUMOTLAR BAZASI (ixtiyoriy, bo'lmasa lokal data/db.json) ---
# Supabase loyihangiz URL'i va xizmat roli kaliti (server tomon).
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- MUHIT -------------------------------------------------
# Productionda "production" qiling (statik build'dan xizmat qiladi va JWT_SECRET majburiy bo'ladi).
NODE_ENV="development"
